{
  "name": "git-changelog-mcp",
  "version": "1.0.0",
  "description": "MCP server that enables AI agents to read git commits and generate beautiful changelogs",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "git-changelog-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "git",
    "changelog",
    "conventional-commits",
    "cursor",
    "claude",
    "ai",
    "llm",
    "release-notes"
  ],
  "author": "kslmisel <jackson.kslmisel@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kslmisel/git-changelog-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/kslmisel/git-changelog-mcp/issues"
  },
  "homepage": "https://github.com/kslmisel/git-changelog-mcp#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "^2.0.0-beta.4",
    "simple-git": "^3.36.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
